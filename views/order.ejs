<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Your Meal - Food Paradise</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-white min-h-screen flex items-center justify-center py-12 px-6">
<div class="bg-zinc-800 rounded-lg p-8 max-w-lg w-full text-center hover:border hover:border-amber-400 transition-all duration-300 hover:shadow-[0_0_20px_rgba(245,158,11,0.6)]">
<h1 class="text-4xl text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-amber-600 font-bold tracking-tighter uppercase">Book Your Tiffin</h1>
<p class="text-zinc-300 mb-8">Fill the details below to start your premium mess service.</p>

<form action="/place-order" method="post" class="space-y-7 text-left">
    <div>
        <label class="block mb-2 text-white uppercase font-bold tracking-tight text-left">Your Name</label>
        <input type="text" name="customerName" required class="w-full rounded-lg p-3 focus:outline-none focus:border-4 focus:border-amber-400 text-black text-lg" placeholder="Enter Name">
    </div>
     <div>
        <label class="block mb-2 text-white uppercase font-bold tracking-tight text-left">Phone Number</label>
        <input type="text" name="phoneNumber" required class="w-full rounded-lg p-3 focus:outline-none focus:border-4 focus:border-amber-400 text-black text-lg" placeholder="Enter phoneNumber">
    </div>
     <div>
        <label class="block mb-2 text-white uppercase font-bold tracking-tight text-left">HOSTEL ROOM / ADDRESS</label>
        <input type="text" name="deliveryAddress" required class="w-full rounded-lg p-3 focus:outline-none focus:border-4 focus:border-amber-400 text-black text-lg" placeholder="HOSTEL ROOM / ADDRESS">
    </div>
    <div>
        <label class="block mb-2 text-white uppercase font-bold tracking-tight text-left">select food items</label>
        <select name="foodItem" required id="" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-lg font-bold focus:border-orange-500 focus:outline-none transition-all text-orange-400">
            <% items.forEach(function(food) { %>
             <option value="<%= food._id %>"><%= food.name%> (Rs . <%= food.price %>)</option>
            <% }) %>
        </select>
    </div>
    <div>
        <label for="" class="block mb-2 text-white uppercase font-bold tracking-tight text-left">Subscription plan</label>
        <select name="planType" required id="" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-lg font-bold focus:border-orange-500 focus:outline-none transition-all text-orange-400">
            <option value="Daily">Daily Basis</option>
            <option value="Weekly">Weekly Subscription</option>
            <option value="Monthly">Monthly Mess Services</option>
        </select>
    </div>
    <div>
        <button type="submit" class="w-full bg-gradient-to-r from-orange-500 to-amber-600 hover:from-orange-600 hover:to-amber-700 text-black font-black uppercase tracking-wider text-sm py-4 rounded-xl shadow-lg transform active:scale-[0.98] transition-all mt-4">Confrim Booking</button>
    </div>
</form>
</div>




